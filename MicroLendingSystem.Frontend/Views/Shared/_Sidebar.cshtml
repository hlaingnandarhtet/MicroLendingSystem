            </div>
        </div> *@
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="nav-item" style="width:100%;border:none;background:none;font:inherit;cursor:pointer;">
                <span class="material-icons">logout</span>
                <span class="nav-label">Logout</span>
            </button>
        </form>
    </div>
</aside>
