@model LoanSettingFormViewModel
@{ ViewData["Title"] = "Add Loan Setting"; ViewData["ActivePage"] = "LoanSettings"; }

<div class="page-header">
    <h1><span class="material-icons">add_circle</span> Add Loan Setting</h1>
    <a asp-action="Index" class="md-btn"><span class="material-icons">arrow_back</span> Back</a>
</div>

<div class="card rounded-3 shadow-sm border-0 ml-card-shell mx-auto ml-form-page">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.PlanName)">Plan name<span class="req">*</span></label>
                    <input asp-for="PlanName" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.InterestRate)">Interest rate (%)<span class="req">*</span></label>
                    <input asp-for="InterestRate" type="number" step="0.01" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.LoanTerm)">Loan term<span class="req">*</span></label>
                    <input asp-for="LoanTerm" type="number" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.CalculationType)">Calculation type<span class="req">*</span></label>
                    <select asp-for="CalculationType" class="form-select ml-form-control" asp-items="Html.GetEnumSelectList<CalculationType>()"></select>
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsActive" type="checkbox" id="IsActive" class="form-check-input" />
                        <label class="form-check-label ml-form-check-label" for="IsActive">Active</label>
                    </div>
                </div>
            </div>
            <div class="ml-form-actions">
                <button type="submit" class="ml-btn-save-form"><span class="material-icons">save</span> Save</button>
                <a asp-action="Index" class="ml-btn-cancel-form">Cancel</a>
            </div>
        </form>
    </div>
</div>
