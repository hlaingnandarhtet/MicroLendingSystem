@model PagedViewModel<LoanSettingDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Loan Settings"; ViewData["ActivePage"] = "LoanSettings";

    bool HasPerm(string perm) =>
        User.Claims.Any(c => c.Type == "Permission" && c.Value == perm);
    bool IsAdmin() =>
        User.IsInRole("Admin") ||
        User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value == "Admin");

    var canCreate = IsAdmin() || HasPerm("Loan Setting Create");
    var canUpdate = IsAdmin() || HasPerm("Loan Setting Update");
    var canDelete = IsAdmin() || HasPerm("Loan Setting Delete");
}

<div class="page-header">
    <h1><span class="material-icons">tune</span> Loan Settings</h1>
    @if (canCreate)
    {
        <a asp-action="Create" class="md-btn md-btn-primary"><span class="material-icons">add</span> Add Setting</a>
    }
</div>

<div class="md-card rounded-3 shadow-sm">
    <div class="table-toolbar">
        <form id="searchForm" method="get" asp-action="Index" class="w-100">
            <div class="row g-2 align-items-end w-100">
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Plan Name</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="planName" value="@ViewBag.PlanName" placeholder="Search plan name..." />
                </div>
                @* <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">&nbsp;</label>
                    <input type="text" class="form-control form-control-md rounded-pill" disabled tabindex="-1" value="" aria-hidden="true" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">&nbsp;</label>
                    <input type="text" class="form-control form-control-md rounded-pill" disabled tabindex="-1" value="" aria-hidden="true" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">&nbsp;</label>
                    <input type="text" class="form-control form-control-md rounded-pill" disabled tabindex="-1" value="" aria-hidden="true" />
                </div> *@
            </div>
        </form>
    </div>
    <div class="table-wrapper">
        <table class="md-table">
            <thead><tr><th>#</th><th>Plan Name</th><th>Interest Rate</th><th>Term</th><th>Type</th><th>Active</th><th>Actions</th></tr></thead>
            <tbody>
            @if (Model.Items.Any())
            {
                int rowNumber = (Model.CurrentPage - 1) * Model.PageSize + 1;
                @foreach (var s in Model.Items)
                {
                    <tr>
                        <td>@rowNumber</td>
                        <td><strong>@s.PlanName</strong></td>
                        <td>@s.InterestRate%</td>
                        <td>@s.LoanTerm</td>
                        <td>@(s.CalculationType == CalculationType.Monthly ? "Monthly" : "Daily")</td>
                        <td><span class="md-chip @(s.IsActive ? "active" : "rejected")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <div class="row-actions">
                                @if (canUpdate)
                                {
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="md-btn-icon edit" title="Edit"><span class="material-icons">edit</span></a>
                                }
                                @if (canDelete)
                                {
                                    <a asp-action="Delete" asp-route-id="@s.Id" class="md-btn-icon delete" title="Delete"><span class="material-icons">delete</span></a>
                                }
                            </div>
                        </td>
                    </tr>
                    rowNumber++;
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state"><span class="material-icons">inbox</span><p>No loan settings found</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.TotalCount > 0)
    {
        <div class="pagination-bar">
            <div class="pagination-info">Showing @Model.StartItem–@Model.EndItem of @Model.TotalCount</div>
            <div class="pagination-controls">
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage-1)" asp-route-planName="@ViewBag.PlanName" 
                   class="page-btn @(!Model.HasPreviousPage?"disabled":"")" title="Previous">
                    <span class="material-icons">chevron_left</span>
                </a>
                
                @if (Model.TotalPages > 1)
                {
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i" asp-route-planName="@ViewBag.PlanName" 
                           class="page-btn @(i==Model.CurrentPage?"active":"")">@i</a>
                    }
                }
                else
                {
                    <span class="page-btn active">1</span>
                }

                <a asp-action="Index" asp-route-page="@(Model.CurrentPage+1)" asp-route-planName="@ViewBag.PlanName" 
                   class="page-btn @(!Model.HasNextPage?"disabled":"")" title="Next">
                    <span class="material-icons">chevron_right</span>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
(function () {
    var inputs = document.querySelectorAll('.search-input');
    var timer;
    inputs.forEach(function (input) {
        input.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                document.getElementById('searchForm').submit();
            }, 450);
        });
        input.addEventListener('change', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                document.getElementById('searchForm').submit();
            }, 200);
        });
    });
})();
</script>
}
