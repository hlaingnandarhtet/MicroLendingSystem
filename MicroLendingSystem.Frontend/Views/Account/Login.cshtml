@model LoginViewModel
@{ ViewData["Title"] = "Login"; ViewData["IsLoginPage"] = true; }

<div class="login-page d-flex align-items-center justify-content-center py-5 px-3">
    <div class="card border-0 shadow rounded-4 overflow-hidden" style="max-width: 420px; width: 100%; border: 1px solid #e8ecf1 !important;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-4 mb-3" style="width: 56px; height: 56px; background: linear-gradient(135deg, #0f2744, #1e3a5c);">
                    <span class="material-icons text-white" style="font-size: 28px;">account_balance</span>
                </div>
                <h2 class="h4 fw-bold mb-1" style="color: #0f2744;">MicroLending</h2>
                <p class="text-muted small mb-0">Sign in to your account</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger border-0 rounded-3 small py-2 px-3 mb-3" role="alert">
                    <span class="material-icons align-middle me-1" style="font-size: 1rem;">error</span>
                    @Model.ErrorMessage
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold" style="color: #1e3a5c;">Email</label>
                    <input asp-for="Email" class="form-control rounded-3 border-secondary-subtle py-2" placeholder="you@example.com" autocomplete="username" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label small fw-semibold" style="color: #1e3a5c;">Password</label>
                    <input asp-for="Password" type="password" class="form-control rounded-3 border-secondary-subtle py-2" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn w-100 rounded-pill fw-semibold py-2 text-white border-0" style="background: #0f2744;">
                    <span class="material-icons align-middle me-1" style="font-size: 1.1rem;">login</span> Sign in
                </button>
            </form>
            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="small text-decoration-none" style="color: #0d9488;">← Back to home</a>
            </div>
        </div>
    </div>
</div>
