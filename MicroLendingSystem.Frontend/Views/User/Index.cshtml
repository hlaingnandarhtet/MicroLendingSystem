@model PagedViewModel<UserDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Users"; ViewData["ActivePage"] = "Users";

    bool HasPerm(string perm) =>
        User.Claims.Any(c => c.Type == "Permission" && c.Value == perm);
    bool IsAdmin() =>
        User.IsInRole("Admin") ||
        User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value == "Admin");

    var canCreate = IsAdmin() || HasPerm("User Create");
    var canUpdate = IsAdmin() || HasPerm("User Update");
    var canDelete = IsAdmin() || HasPerm("User Delete");
}

<div class="page-header">
    <h1><span class="material-icons">manage_accounts</span> Users</h1>
    @if (canCreate)
    {
        <a asp-action="Create" class="md-btn md-btn-primary"><span class="material-icons">add</span> Add User</a>
    }
</div>

<div class="md-card rounded-3 shadow-sm">
    <div class="table-toolbar">
        <form id="searchForm" method="get" asp-action="Index" class="w-100">
            <div class="row g-2 align-items-end w-100">
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Name</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="name" value="@ViewBag.Name" placeholder="Search name..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Email</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="email" value="@ViewBag.Email" placeholder="Search email..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Role</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="role" value="@ViewBag.Role" placeholder="Search role..." />
                </div>
                @* <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">&nbsp;</label>
                    <input type="text" class="form-control form-control-md rounded-pill" disabled tabindex="-1" value="" aria-hidden="true" />
                </div> *@
            </div>
        </form>
    </div>
    <div class="table-wrapper">
        <table class="md-table">
            <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Role</th><th>Created</th><th>Actions</th></tr></thead>
            <tbody>
            @if (Model.Items.Any())
            {
                int rowNumber = (Model.CurrentPage - 1) * Model.PageSize + 1;
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@rowNumber</td>
                        <td><strong>@u.Name</strong></td>
                        <td>@u.Email</td>
                        <td><span class="md-chip @(u.RoleName == "Admin" ? "active" : "pending")">@u.RoleName</span></td>
                        <td>@u.CreatedAt?.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="row-actions">
                                @if (canUpdate)
                                {
                                    <a asp-action="Edit" asp-route-id="@u.Id" class="md-btn-icon edit" title="Edit"><span class="material-icons">edit</span></a>
                                }
                                @if (canDelete)
                                {
                                    <a asp-action="Delete" asp-route-id="@u.Id" class="md-btn-icon delete" title="Delete"><span class="material-icons">delete</span></a>
                                }
                            </div>
                        </td>
                    </tr>
                    rowNumber++;
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state"><span class="material-icons">inbox</span><p>No users found</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.TotalCount > 0)
    {
        <div class="pagination-bar">
            <div class="pagination-info">Showing @Model.StartItem–@Model.EndItem of @Model.TotalCount</div>
            <div class="pagination-controls">
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage-1)" asp-route-name="@ViewBag.Name" asp-route-email="@ViewBag.Email" asp-route-role="@ViewBag.Role" 
                   class="page-btn @(!Model.HasPreviousPage?"disabled":"")" title="Previous">
                    <span class="material-icons">chevron_left</span>
                </a>
                
                @if (Model.TotalPages > 1)
                {
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i" asp-route-name="@ViewBag.Name" asp-route-email="@ViewBag.Email" asp-route-role="@ViewBag.Role" 
                           class="page-btn @(i==Model.CurrentPage?"active":"")">@i</a>
                    }
                }
                else
                {
                    <span class="page-btn active">1</span>
                }

                <a asp-action="Index" asp-route-page="@(Model.CurrentPage+1)" asp-route-name="@ViewBag.Name" asp-route-email="@ViewBag.Email" asp-route-role="@ViewBag.Role" 
                   class="page-btn @(!Model.HasNextPage?"disabled":"")" title="Next">
                    <span class="material-icons">chevron_right</span>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
(function () {
    var inputs = document.querySelectorAll('.search-input');
    var timer;
    inputs.forEach(function (input) {
        input.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                document.getElementById('searchForm').submit();
            }, 450);
        });
        input.addEventListener('change', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                document.getElementById('searchForm').submit();
            }, 200);
        });
    });
})();
</script>
}
