@model UserFormViewModel
@{ ViewData["Title"] = "Create User"; ViewData["ActivePage"] = "Users"; }

<div class="page-header">
    <h1><span class="material-icons">add_circle</span> Create User</h1>
    <a asp-action="Index" class="md-btn"><span class="material-icons">arrow_back</span> Back</a>
</div>

<div class="card rounded-3 shadow-sm border-0 ml-card-shell mx-auto ml-form-page">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.Name)">Full name<span class="req">*</span></label>
                    <input asp-for="Name" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.Email)">Email<span class="req">*</span></label>
                    <input asp-for="Email" type="email" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.Password)">Password<span class="req">*</span></label>
                    <input asp-for="Password" type="password" class="form-control ml-form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="ml-form-label mb-1 d-block" for="@Html.IdFor(m => m.RoleId)">Role<span class="req">*</span></label>
                    <select asp-for="RoleId" class="form-select ml-form-control" required>
                        <option value="">Select role…</option>
                        @foreach (var r in Model.Roles)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="ml-form-actions">
                <button type="submit" class="ml-btn-save-form"><span class="material-icons">save</span> Save</button>
                <a asp-action="Index" class="ml-btn-cancel-form">Cancel</a>
            </div>
        </form>
    </div>
</div>
