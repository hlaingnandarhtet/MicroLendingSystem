@model LoanIndexViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Loans"; ViewData["ActivePage"] = "Loans";

    bool HasPerm(string perm) =>
        User.Claims.Any(c => c.Type == "Permission" && c.Value == perm);
    bool IsAdmin() =>
        User.IsInRole("Admin") ||
        User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value == "Admin");

    // var canCreate  = IsAdmin() || HasPerm("Loan_Create");
    // var canUpdate  = IsAdmin() || HasPerm("Loan_Update");
    // var canDelete  = IsAdmin() || HasPerm("Loan_Delete");
    // var canApprove = IsAdmin() || HasPerm("Loan_Approve");
    var canCreate = IsAdmin() || HasPerm("Loan Create");
    var canUpdate = IsAdmin() || HasPerm("Loan Update");
    var canDelete = IsAdmin() || HasPerm("Loan Delete");
    var canApprove = IsAdmin() || HasPerm("Loan Approve");
}

<div class="page-header">
    <h1><span class="material-icons">request_quote</span> Loans</h1>
    @if (canCreate)
    {
        <a asp-action="Create" class="md-btn md-btn-primary"><span class="material-icons">add</span> Create Loan</a>
    }
</div>

<div class="md-card">
    @* <div class="table-toolbar">
        <form id="searchForm" method="get" asp-action="Index">
            <div class="table-search">
                <span class="material-icons">search</span>
                <input type="text" id="tableSearch" name="search" value="@Model.SearchTerm" placeholder="Search loans..." />
            </div>
            <input type="hidden" name="status" value="@Model.StatusFilter" />
        </form>
        <div class="filter-bar">
            <a asp-action="Index" class="md-filter-chip @(Model.StatusFilter == null ? "active" : "")">All</a>
            <a asp-action="Index" asp-route-status="1" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Pending ? "active" : "")">Pending</a>
            <a asp-action="Index" asp-route-status="2" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Active ? "active" : "")">Active</a>
            <a asp-action="Index" asp-route-status="3" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Complete ? "active" : "")">Complete</a>
            <a asp-action="Index" asp-route-status="4" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Overdue ? "active" : "")">Overdue</a>
        </div>
    </div> *@
    <div class="table-toolbar">
        <form id="searchForm" method="get" asp-action="Index">
            <div class="table-search">
                <label class="form-label small text-muted mb-1">Loan Code</label>
                <input type="text" class="form-control form-control-md rounded-pill search-input" id="tableSearch" name="search" value="@Model.SearchTerm" placeholder="Search loans..." />
            </div>
            <input type="hidden" name="status" value="@Model.StatusFilter" />
        </form>
        <div class="filter-bar">
            <a asp-action="Index" class="md-filter-chip @(Model.StatusFilter == null ? "active" : "")">All</a>
            <a asp-action="Index" asp-route-status="1" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Pending ? "active" : "")">Pending</a>
            <a asp-action="Index" asp-route-status="2" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Active ? "active" : "")">Active</a>
            <a asp-action="Index" asp-route-status="3" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Complete ? "active" : "")">Complete</a>
            <a asp-action="Index" asp-route-status="4" class="md-filter-chip @(Model.StatusFilter == LoanStatus.Overdue ? "active" : "")">Overdue</a>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="md-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Code</th>
                    <th>Borrower</th>
                    <th>Amount</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Items.Any())
            {   
                   
                int rowNumber = 1;
                @foreach (var item in Model.Items)
                {
                    var cls = item.Status switch { 1 => "pending", 2 => "active", 3 => "complete", 4 => "overdue", _ => "rejected" };
                    var lbl = item.Status switch { 1 => "Pending", 2 => "Active", 3 => "Complete", 4 => "Overdue", _ => "Rejected" };
                    <tr id="loan-row-@item.Id">
                        <td>@rowNumber</td>
                        <td><strong>@item.LoanCode</strong></td>
                        <td>@item.Borrower?.FullName</td>
                        <td>@item.LoanAmount.ToString("N0")</td>
                        <td>@item.PlanName</td>
                        <td><span class="md-chip @cls" id="loan-status-@item.Id">@lbl</span></td>
                        <td>@item.CreatedAt?.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="row-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="md-btn-icon view" title="View"><span class="material-icons">visibility</span></a>
                                @if (canUpdate)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="md-btn-icon edit" title="Edit"><span class="material-icons">edit</span></a>
                                }
                                @if (canDelete)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="md-btn-icon delete" title="Delete"><span class="material-icons">delete</span></a>
                                }
                                @if (canApprove && item.Status == 1)
                                {
                                    <button type="button" class="md-btn-icon approve-btn" title="Approve"
                                            onclick="approveLoan(@item.Id)" style="color:#4CAF50;background:none;border:none;cursor:pointer;">
                                        <span class="material-icons">check_circle</span>
                                    </button>
                                    <button type="button" class="md-btn-icon reject-btn" title="Reject"
                                            onclick="rejectLoan(@item.Id)" style="color:#F44336;background:none;border:none;cursor:pointer;">
                                        <span class="material-icons">cancel</span>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                        rowNumber++;
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state"><span class="material-icons">inbox</span><p>No loans found</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.TotalCount > 0)
    {
        <div class="pagination-bar">
            <div class="pagination-info">Showing @Model.StartItem–@Model.EndItem of @Model.TotalCount</div>
            <div class="pagination-controls">
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage-1)" asp-route-status="@Model.StatusFilter" 
                   class="page-btn @(!Model.HasPreviousPage?"disabled":"")" title="Previous">
                    <span class="material-icons">chevron_left</span>
                </a>
                
                @if (Model.TotalPages > 1)
                {
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i" asp-route-status="@Model.StatusFilter" 
                           class="page-btn @(i==Model.CurrentPage?"active":"")">@i</a>
                    }
                }
                else
                {
                    <span class="page-btn active">1</span>
                }

                <a asp-action="Index" asp-route-page="@(Model.CurrentPage+1)" asp-route-status="@Model.StatusFilter" 
                   class="page-btn @(!Model.HasNextPage?"disabled":"")" title="Next">
                    <span class="material-icons">chevron_right</span>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    (function () {
        var st = '@(Model.StatusFilter.HasValue ? ((int)Model.StatusFilter.Value).ToString() : "")';
        var sel = document.getElementById('loanStatusFilter');
        if (sel && st) {
            for (var i = 0; i < sel.options.length; i++) {
                if (sel.options[i].value === st) { sel.selectedIndex = i; break; }
            }
        }
        var inputs = document.querySelectorAll('.search-input');
        var timer;
        inputs.forEach(function (input) {
            input.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(function () {
                    document.getElementById('searchForm').submit();
                }, 450);
            });
            input.addEventListener('change', function () {
                clearTimeout(timer);
                timer = setTimeout(function () {
                    document.getElementById('searchForm').submit();
                }, 200);
            });
        });
    })();

    function approveLoan(loanId) {
        if (!confirm('Are you sure you want to APPROVE this loan?')) return;
        updateLoanStatus(loanId, 2);
    }
    function rejectLoan(loanId) {
        if (!confirm('Are you sure you want to REJECT this loan?')) return;
        updateLoanStatus(loanId, 5);
    }
    function updateLoanStatus(loanId, statusId) {
        fetch('@Url.Action("ApproveReject", "Loan")' + '?id=' + loanId + '&statusId=' + statusId, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
        })
        .then(r => r.json())
        .then(data => { if (data.success) location.reload(); else alert(data.message); })
        .catch(() => alert('Request failed'));
    }
</script>
}
