@model PagedViewModel<BorrowerDto>
@using System.Security.Claims
@{
    ViewData["Title"] = "Borrowers";
    ViewData["ActivePage"] = "Borrowers";

    bool HasPerm(string perm) =>
        User.Claims.Any(c => c.Type == "Permission" && c.Value == perm);
    bool IsAdmin() =>
        User.IsInRole("Admin") ||
        User.Claims.Any(c => c.Type == ClaimTypes.Role && c.Value == "Admin");

    var canCreate = IsAdmin() || HasPerm("Borrower Create");
    var canUpdate = IsAdmin() || HasPerm("Borrower Update");
    var canDelete = IsAdmin() || HasPerm("Borrower Delete");
}

<div class="page-header">
    <h1><span class="material-icons">people</span> Borrowers</h1>
    @if (canCreate)
    {
        <a asp-action="Create" class="md-btn md-btn-primary">
            <span class="material-icons">add</span> Add Borrower
        </a>
    }
</div>

<div class="md-card rounded-3 shadow-sm">
    <div class="table-toolbar">
        <form id="searchForm" method="get" asp-action="Index" class="w-100">
            <div class="row g-2 align-items-end w-100">
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Full Name</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="fullName" value="@ViewBag.FullName" placeholder="Search name..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Username</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="userName" value="@ViewBag.UserName" placeholder="Search username..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Phone</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="phoneNo" value="@ViewBag.PhoneNo" placeholder="Search phone..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">NRC</label>
                    <input type="text" class="form-control form-control-md rounded-pill search-input" name="nrcNo" value="@ViewBag.NrcNo" placeholder="Search NRC..." />
                </div>
            </div>
        </form>
    </div>

    <div class="table-wrapper">
        <table class="md-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>NRC</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    int rowNumber = (Model.CurrentPage - 1) * Model.PageSize + 1;
                    foreach (var b in Model.Items)
                    {
                        <tr>
                            <td>@rowNumber</td>
                            <td><strong>@b.FullName</strong></td>
                            <td>@b.UserName</td>
                            <td>@b.Nrcno</td>
                            <td>@b.PhoneNo</td>
                            <td class="text-truncate" style="max-width: 150px;">@b.Address</td>
                            <td>@b.CreatedAt?.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="row-actions">
                                    <a asp-action="Details" asp-route-id="@b.Id" class="md-btn-icon view" title="View">
                                        <span class="material-icons">visibility</span>
                                    </a>
                                    @if (canUpdate)
                                    {
                                        <a asp-action="Edit" asp-route-id="@b.Id" class="md-btn-icon edit" title="Edit">
                                            <span class="material-icons">edit</span>
                                        </a>
                                    }
                                    @if (canDelete)
                                    {
                                        <a asp-action="Delete" asp-route-id="@b.Id" class="md-btn-icon delete" title="Delete">
                                            <span class="material-icons">delete</span>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                        rowNumber++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <span class="material-icons">inbox</span>
                                <p>No borrowers found</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-bar">
            <div class="pagination-info">Showing @Model.StartItem–@Model.EndItem of @Model.TotalCount</div>
            <div class="pagination-controls">
                <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-fullName="@ViewBag.FullName"
                   asp-route-userName="@ViewBag.UserName"
                   asp-route-phoneNo="@ViewBag.PhoneNo"
                   asp-route-nrcNo="@ViewBag.NrcNo"
                   class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                    <span class="material-icons">chevron_left</span>
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index" asp-route-page="@i"
                       asp-route-fullName="@ViewBag.FullName"
                       asp-route-userName="@ViewBag.UserName"
                       asp-route-phoneNo="@ViewBag.PhoneNo"
                       asp-route-nrcNo="@ViewBag.NrcNo"
                       class="page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }

                <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-fullName="@ViewBag.FullName"
                   asp-route-userName="@ViewBag.UserName"
                   asp-route-phoneNo="@ViewBag.PhoneNo"
                   asp-route-nrcNo="@ViewBag.NrcNo"
                   class="page-btn @(!Model.HasNextPage ? "disabled" : "")">
                    <span class="material-icons">chevron_right</span>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var inputs = document.querySelectorAll('.search-input');
            var timer;
            inputs.forEach(function (input) {
                input.addEventListener('input', function () {
                    clearTimeout(timer);
                    timer = setTimeout(function () {
                        document.getElementById('searchForm').submit();
                    }, 450);
                });
                input.addEventListener('change', function () {
                    clearTimeout(timer);
                    timer = setTimeout(function () {
                        document.getElementById('searchForm').submit();
                    }, 200);
                });
            });
        })();
    </script>
}
